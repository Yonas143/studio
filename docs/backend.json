
{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "role": {
          "type": "string",
          "enum": ["participant", "judge", "admin"],
          "description": "The user's role in the system."
        }
      },
      "required": ["uid", "email", "role"]
    },
    "submission": {
      "title": "Submission",
      "description": "Represents a user's submission to the awards.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the submission."
        },
        "categoryId": {
          "type": "string",
          "description": "The ID of the category this submission belongs to."
        },
        "submitterId": {
          "type": "string",
          "description": "The UID of the user who submitted this."
        },
        "culturalRelevance": {
          "type": "string",
          "description": "Explanation of the submission's cultural relevance."
        },
        "mediaUrl": {
          "type": "string",
          "description": "URL to the uploaded media file."
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Approved", "Rejected"],
          "description": "The review status of the submission."
        },
        "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the submission was created."
        }
      },
      "required": ["title", "categoryId", "submitterId", "culturalRelevance", "status", "createdAt"]
    },
    "vote": {
        "title": "Vote",
        "description": "Represents a single vote cast by a user for a nominee.",
        "type": "object",
        "properties": {
            "userId": {
                "type": "string",
                "description": "The UID of the user who voted."
            },
            "nomineeId": {
                "type": "string",
                "description": "The ID of the nominee being voted for."
            },
            "createdAt": {
                "type": "string",
                "format": "date-time",
                "description": "Timestamp when the vote was cast."
            }
        },
        "required": ["userId", "nomineeId", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/userProfile"
      },
      "description": "Stores public profiles for all users."
    },
    "/submissions/{submissionId}": {
        "schema": {
            "$ref": "#/entities/submission"
        },
        "description": "Stores all submissions from participants."
    },
    "/votes/{voteId}": {
        "schema": {
            "$ref": "#/entities/vote"
        },
        "description": "Stores all votes cast by users."
    }
  }
}
