generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String   @default("participant")
  photoURL  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@map("users")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  nominees    Nominee[]

  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

model Nominee {
  id         String         @id @default(uuid())
  name       String
  bio        String?
  imageUrl   String?
  videoUrl   String?
  categoryId String
  scope      String         @default("ethiopia")
  featured   Boolean        @default(false)
  voteCount  Int            @default(0)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  region     String?
  category   Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  media      NomineeMedia[]
  votes      Vote[]

  @@index([categoryId])
  @@index([scope])
  @@index([featured])
  @@index([isActive])
  @@index([voteCount])
  @@map("nominees")
}

model NomineeMedia {
  id          String   @id @default(uuid())
  nomineeId   String
  type        String
  url         String
  thumbnail   String
  description String
  hint        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  nominee     Nominee  @relation(fields: [nomineeId], references: [id], onDelete: Cascade)

  @@index([nomineeId])
  @@map("nominee_media")
}

model Vote {
  id          String   @id @default(uuid())
  nomineeId   String
  userId      String?  // Made optional for public voting
  ipAddress   String?
  fingerprint String?
  createdAt   DateTime @default(now())
  nominee     Nominee  @relation(fields: [nomineeId], references: [id], onDelete: Cascade)

  @@unique([userId, nomineeId]) // Note: This constraint might need adjustment if userId is null, but Postgres handles unique nulls differently (usually allows multiple nulls). 
  // However, we want to enforce unique vote per user IF logged in.
  // If not logged in, we rely on ipAddress checks in code, not DB constraints for uniqueness.
  
  @@index([ipAddress])
  @@index([nomineeId])
  @@index([createdAt])
  @@map("votes")
}

model Submission {
  id           String   @id @default(uuid())
  title        String
  description  String?
  category     String
  fileUrl      String?
  fullName     String
  email        String
  phone        String?
  portfolioUrl String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([email])
  @@map("submissions")
}

model Popup {
  id           String   @id @default(uuid())
  type         String
  title        String
  description  String?
  videoUrl     String?
  imageUrl     String?
  imageLink    String?
  isActive     Boolean  @default(true)
  delaySeconds Int      @default(2)
  storageKey   String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([storageKey])
  @@map("popups")
}

model TimelineEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([isActive])
  @@index([order])
  @@map("timeline_events")
}

model CulturalInsight {
  id          String   @id @default(uuid())
  title       String
  content     String
  author      String?
  imageUrl    String?
  category    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([category])
  @@map("cultural_insights")
}

model AdConfig {
  id            String   @id @default("default")
  leftAdImage   String?
  leftAdLink    String?
  leftAdActive  Boolean  @default(true)
  rightAdImage  String?
  rightAdLink   String?
  rightAdActive Boolean  @default(true)
  updatedAt     DateTime @updatedAt

  @@map("ad_config")
}
