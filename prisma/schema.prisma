// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  role          String   @default("participant") // superadmin, admin, participant
  photoURL      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  // submissions   Submission[] // Removed for public access
  // votes         Vote[]       // Removed for public access
  
  @@index([email])
  @@index([role])
}

// Category model
model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  nominees    Nominee[]
  
  @@index([slug])
  @@index([isActive])
}

// Nominee model
model Nominee {
  id          String   @id @default(uuid())
  name        String
  bio         String?
  imageUrl    String?
  videoUrl    String?
  categoryId  String
  region      String?
  scope       String   @default("ethiopia") // "ethiopia" or "worldwide"
  featured    Boolean  @default(false)
  voteCount   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  votes       Vote[]
  payments    Payment[]
  media       NomineeMedia[]
  
  @@index([categoryId])
  @@index([scope])
  @@index([featured])
  @@index([isActive])
  @@index([voteCount])
}

model NomineeMedia {
  id          String   @id @default(uuid())
  nomineeId   String
  type        String   // image, video, audio
  url         String
  thumbnail   String
  description String
  hint        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nominee     Nominee  @relation(fields: [nomineeId], references: [id], onDelete: Cascade)

  @@index([nomineeId])
}

// Vote model - Now linked to verified payments
model Vote {
  id          String   @id @default(uuid())
  nomineeId   String
  paymentId   String   @unique  // Link to verified payment
  ipAddress   String?  // Keep for additional rate limiting if needed
  fingerprint String?  // Browser fingerprint
  createdAt   DateTime @default(now())
  
  // Relations
  nominee     Nominee  @relation(fields: [nomineeId], references: [id], onDelete: Cascade)
  payment     Payment  @relation(fields: [paymentId], references: [id])
  
  @@index([ipAddress])
  @@index([nomineeId])
  @@index([createdAt])
}

// Payment model - Tracks Chapa transactions
model Payment {
  id            String    @id @default(uuid())
  txRef         String    @unique  // Unique transaction reference
  chapaRef      String?   // Chapa's reference ID (from verification)
  nomineeId     String
  amount        Float     @default(10.0)
  currency      String    @default("ETB")
  status        String    @default("pending") // pending, success, failed
  email         String?
  firstName     String?
  lastName      String?
  phone         String?
  fingerprint   String?
  ipAddress     String?
  checkoutUrl   String?   // Chapa checkout URL
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  verifiedAt    DateTime?

  // Relations
  nominee       Nominee   @relation(fields: [nomineeId], references: [id], onDelete: Cascade)
  vote          Vote?     // One-to-one with Vote (created after successful payment)

  @@index([status])
  @@index([nomineeId])
  @@index([txRef])
}


// Submission model
model Submission {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String
  fileUrl     String?
  
  // Submitter Info (Public)
  fullName    String
  email       String
  phone       String?
  portfolioUrl String?
  
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([category])
  @@index([email])
}

// Popup model
model Popup {
  id            String   @id @default(uuid())
  type          String   // video, image, text
  title         String
  description   String?
  videoUrl      String?
  imageUrl      String?
  imageLink     String?
  isActive      Boolean  @default(true)
  delaySeconds  Int      @default(2)
  storageKey    String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([isActive])
  @@index([storageKey])
}

// Timeline Event model
model TimelineEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([date])
  @@index([isActive])
  @@index([order])
}

// Cultural Insight model
model CulturalInsight {
  id          String   @id @default(uuid())
  title       String
  content     String
  author      String?
  imageUrl    String?
  category    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isPublished])
  @@index([category])
}

// Ad Configuration model
model AdConfig {
  id            String   @id @default("default")
  leftAdImage   String?
  leftAdLink    String?
  leftAdActive  Boolean  @default(true)
  rightAdImage  String?
  rightAdLink   String?
  rightAdActive Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}
