// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User model
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  role          String   @default("participant") // admin, judge, participant
  photoURL      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  // submissions   Submission[] // Removed for public access
  // votes         Vote[]       // Removed for public access
  
  @@index([email])
  @@index([role])
}

// Category model
model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  nominees    Nominee[]
  
  @@index([slug])
  @@index([isActive])
}

// Nominee model
model Nominee {
  id          String   @id @default(cuid())
  name        String
  bio         String?
  imageUrl    String?
  videoUrl    String?
  categoryId  String
  scope       String   @default("ethiopia") // "ethiopia" or "worldwide"
  featured    Boolean  @default(false)
  voteCount   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  votes       Vote[]
  
  @@index([categoryId])
  @@index([scope])
  @@index([featured])
  @@index([isActive])
  @@index([voteCount])
}

// Vote model
model Vote {
  id         String   @id @default(cuid())
  nomineeId  String
  ipAddress  String?  // For rate limiting
  fingerprint String? // Browser fingerprint
  createdAt  DateTime @default(now())
  
  // Relations
  nominee    Nominee  @relation(fields: [nomineeId], references: [id], onDelete: Cascade)
  
  // Ensure one vote per IP per nominee (basic protection)
  @@index([ipAddress])
  @@index([nomineeId])
  @@index([createdAt])
}

// Submission model
model Submission {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  fileUrl     String?
  
  // Submitter Info (Public)
  fullName    String
  email       String
  phone       String?
  portfolioUrl String?
  
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([category])
  @@index([email])
}

// Popup model
model Popup {
  id            String   @id @default(cuid())
  type          String   // video, image, text
  title         String
  description   String?
  videoUrl      String?
  imageUrl      String?
  imageLink     String?
  isActive      Boolean  @default(true)
  delaySeconds  Int      @default(2)
  storageKey    String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([isActive])
  @@index([storageKey])
}

// Timeline Event model
model TimelineEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([date])
  @@index([isActive])
  @@index([order])
}

// Cultural Insight model
model CulturalInsight {
  id          String   @id @default(cuid())
  title       String
  content     String
  author      String?
  imageUrl    String?
  category    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isPublished])
  @@index([category])
}

// Ad Configuration model
model AdConfig {
  id            String   @id @default("default")
  leftAdImage   String?
  leftAdLink    String?
  leftAdActive  Boolean  @default(true)
  rightAdImage  String?
  rightAdLink   String?
  rightAdActive Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}
